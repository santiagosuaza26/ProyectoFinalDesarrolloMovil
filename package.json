{
  "name": "didiclone",
  "version": "1.0.0",
  "private": true,
  "description": "React Native CLI MVP for a Didi-style ride-hailing mobile app with Firebase, Google Maps, Redux, i18n, and Stripe demo payments.",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "e2e:android:avds": "node e2e/run-detox.js --list-avds",
    "test:e2e:build:android": "node e2e/run-detox.js build --configuration android.emu.debug",
    "test:e2e:android": "node e2e/run-detox.js test --configuration android.emu.debug",
    "lint": "eslint . --ext .js,.jsx",
    "typecheck": "node -e \"console.log('JavaScript project: no TypeScript typecheck')\"",
    "stripe:dev": "node server/stripe-server.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.24.0",
    "@react-native-community/geolocation": "3.4.0",
    "@react-native-firebase/app": "21.7.1",
    "@react-native-firebase/auth": "21.7.1",
    "@react-native-firebase/firestore": "21.7.1",
    "@react-native-firebase/storage": "21.7.1",
    "@react-navigation/bottom-tabs": "^7.0.14",
    "@react-navigation/native": "^7.0.13",
    "@react-navigation/native-stack": "^7.1.14",
    "@reduxjs/toolkit": "^2.5.0",
    "@stripe/stripe-react-native": "0.40.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "i18next": "^24.2.0",
    "react": "18.3.1",
    "react-i18next": "^15.4.0",
    "react-native": "0.76.5",
    "react-native-config": "^1.5.3",
    "react-native-gesture-handler": "2.21.2",
    "react-native-google-places-autocomplete": "^2.5.7",
    "react-native-image-picker": "^7.2.3",
    "react-native-maps": "1.18.0",
    "react-native-maps-directions": "1.9.0",
    "react-native-reanimated": "3.16.6",
    "react-native-safe-area-context": "5.0.0",
    "react-native-screens": "4.4.0",
    "react-redux": "^9.2.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@react-native-community/cli": "^15.1.3",
    "@react-native-community/cli-platform-android": "^15.1.3",
    "@react-native-community/cli-platform-ios": "^15.1.3",
    "@react-native/babel-preset": "0.76.5",
    "@react-native/eslint-config": "0.76.5",
    "@react-native/metro-config": "0.76.5",
    "@testing-library/react-native": "^12.9.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "detox": "^20.27.2",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "react-test-renderer": "18.3.1"
  },
  "detox": {
    "testRunner": {
      "args": {
        "$0": "jest",
        "config": "e2e/jest.config.js"
      },
      "jest": {
        "setupTimeout": 120000
      }
    },
    "apps": {
      "android.debug": {
        "type": "android.apk",
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "testBinaryPath": "android/app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk",
        "build": "cd android && gradlew.bat :app:assembleDebug :app:assembleAndroidTest -DtestBuildType=debug"
      }
    },
    "devices": {
      "android.emulator": {
        "type": "android.emulator",
        "device": {
          "avdName": "Medium_Phone"
        }
      }
    },
    "configurations": {
      "android.emu.debug": {
        "device": "android.emulator",
        "app": "android.debug"
      }
    }
  },
  "engines": {
    "node": ">=18"
  }
}
